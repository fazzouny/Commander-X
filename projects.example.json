{
  "codex": {
    "sandbox": "workspace-write",
    "approval_policy": "never",
    "extra_args": []
  },
  "projects": {
    "example-app": {
      "display_name": "Example App",
      "path": "C:\\path\\to\\your\\project",
      "allowed": true,
      "default_branch": "main",
      "create_branch_on_start": true,
      "aliases": [
        "example",
        "app"
      ],
      "context_files": [
        "AGENTS.md",
        "README.md",
        "package.json"
      ]
    }
  }
}
