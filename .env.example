# Commander X core
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_CONFIGURE_BOT_ON_START=true

# OpenAI
OPENAI_API_KEY=
OPENAI_COMMAND_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-4o-mini
OPENAI_IMAGE_PROMPT=Analyze this Telegram image for Commander X. Summarize the useful operator context, visible issue, important visible text, and safest next Commander actions. Never reproduce secrets, tokens, private keys, credentials, or full local paths.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIBE_PROMPT=Transcribe this as a command for Codex Commander. Preserve project IDs, approval IDs, branch names, command words, and technical terms exactly.
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE=alloy
COMMANDER_MAX_IMAGE_BYTES=10485760

# Heartbeat automation
COMMANDER_HEARTBEAT_MINUTES=30
COMMANDER_HEARTBEAT_QUIET_START=23:00
COMMANDER_HEARTBEAT_QUIET_END=08:00

# Dashboard
COMMANDER_DASHBOARD_HOST=127.0.0.1
COMMANDER_DASHBOARD_PORT=8787
COMMANDER_DASHBOARD_TOKEN=
COMMANDER_DASHBOARD_CACHE_SECONDS=8
COMMANDER_DASHBOARD_BACKGROUND_REFRESH_SECONDS=45
COMMANDER_DASHBOARD_REQUEST_REFRESH_SECONDS=45
COMMANDER_DASHBOARD_WARM_CACHE_ON_START=true
COMMANDER_DASHBOARD_MCP_CACHE_SECONDS=300
COMMANDER_DASHBOARD_MCP_TIMEOUT_SECONDS=8
COMMANDER_SERVICE_RESTART_COOLDOWN_SECONDS=120
COMMANDER_REPORT_DIR=reports
COMMANDER_REPORT_LIMIT=12
COMMANDER_BACKUP_DIR=backups
COMMANDER_MCP_WEB_RESEARCH=true
COMMANDER_MCP_RESEARCH_TIMEOUT_SECONDS=12
COMMANDER_MCP_TRUSTED_NPM_SCOPES=@modelcontextprotocol,@upstash,@supabase,@cloudflare,@github,@vercel,@netlify

# OpenClaw recovery / launcher detection
COMMANDER_OPENCLAW_LAUNCHER=
COMMANDER_OPENCLAW_REPO_URL=
COMMANDER_OPENCLAW_INSTALL_TARGET=
COMMANDER_OPENCLAW_WEB_RESEARCH=true
COMMANDER_OPENCLAW_RESEARCH_TIMEOUT_SECONDS=12
COMMANDER_OPENCLAW_PROCESS_TIMEOUT_SECONDS=8

# Browser/device broker
COMMANDER_BROWSER_HEADLESS=true
COMMANDER_BROWSER_TIMEOUT_SECONDS=30
COMMANDER_ALLOW_CLIPBOARD_READ=true
COMMANDER_ALLOW_SCREENSHOT=true
COMMANDER_ALLOW_VOLUME_KEYS=true
COMMANDER_CLEANUP_MAX_FILES=20000
COMMANDER_CLEANUP_SECONDS_PER_TARGET=2

# ClickUp API bridge
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_TEAM_ID=

# Meta Ads / future MCP connector credentials
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=

# GitHub bridge
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_DEFAULT_REPO=

# WhatsApp Cloud API bridge
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Gmail / Google Workspace future bridges
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GMAIL_LABEL_PREFIX=CommanderX

# Microsoft 365 / Outlook future bridge
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REFRESH_TOKEN=

# Project/cloud provider bridges
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
RENDER_API_KEY=
CLOUDINARY_URL=

# Payments/business bridges
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=

# Optional notification/webhook bridges
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Safety defaults
COMMANDER_REQUIRE_APPROVAL_FOR_PUSH=true
COMMANDER_REQUIRE_APPROVAL_FOR_DEPLOY=true
COMMANDER_REQUIRE_APPROVAL_FOR_EXTERNAL_SEND=true
COMMANDER_REQUIRE_APPROVAL_FOR_PACKAGE_INSTALL=true
